# ─── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/app_db?schema=public"

# ─── JWT Authentication ───────────────────────────────────
JWT_SECRET="change-me-in-production-use-a-random-64-char-string"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="change-me-in-production-use-another-random-64-char-string"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── Email (SMTP) ─────────────────────────────────────────
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="noreply@example.com"

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── App ───────────────────────────────────────────────────
APP_NAME="MyApp"
API_PORT=3001
API_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Sentry (optional) ────────────────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
