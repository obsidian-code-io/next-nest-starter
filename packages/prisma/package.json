{
  "name": "@monorepo/prisma",
  "version": "0.0.1",
  "private": true,
  "main": "index.ts",
  "types": "index.ts",
  "scripts": {
    "build": "bunx prisma generate --schema=schema",
    "db:migrate": "bunx prisma migrate dev --schema=schema",
    "db:push": "bunx prisma db push --schema=schema",
    "db:seed": "bun run seed.ts",
    "studio": "bunx prisma studio --schema=schema",
    "clean": "rm -rf node_modules/.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0"
  },
  "devDependencies": {
    "prisma": "^6.6.0",
    "typescript": "^5.7.0"
  },
  "prisma": {
    "seed": "bun run seed.ts"
  }
}
